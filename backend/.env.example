# ====== Backend Environment Variables ======
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env file to GitHub.

# Server port (Render sets PORT automatically; this is for local dev)
PORT=5000

# MongoDB connection string (get a free cluster from https://www.mongodb.com/atlas)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/collegeportal?retryWrites=true&w=majority

# Secret used to sign login tokens (use a long random string)
JWT_SECRET=change_this_to_a_long_random_secret_string

# How long a login stays valid
JWT_EXPIRES_IN=7d

# Razorpay keys (get from https://dashboard.razorpay.com -> Settings -> API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Price configuration (in paise: 65 INR = 6500 paise, 600 INR = 60000 paise)
SINGLE_COLLEGE_PRICE=6500
FULL_PACKAGE_PRICE=60000

# Frontend URL allowed to call this API (your Netlify / custom domain)
# For local dev use http://localhost:5173
CLIENT_URL=http://localhost:5173
